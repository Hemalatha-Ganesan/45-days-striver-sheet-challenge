class Solution {
    public List<Integer> majorityElementTwo(int[] nums) {
        List<Integer> res = new ArrayList<>();
        HashMap<Integer,Integer> hm  = new HashMap<>();
        for(int num:nums)
        {
            hm.put(num,hm.getOrDefault(num,0)+1);
        }
        int n = nums.length;
        for(int key: hm.keySet())
        {
            if(hm.get(key) > n/3)
            {
                res.add(key);
            }
        }
        return res;
    }
}
