class Solution {
    public int stockBuySell(int[] arr, int n) {
        int profit = 0, max = 0;
       int min = arr[0];
       for(int i=1;i<n;i++)
       {
          if(arr[i] < min){
             min = arr[i];
          }
          else{
             profit = arr[i] - min;
             if(profit > max)
             {
                max = profit;
             }
          }
       }
       return max;
    }
}
